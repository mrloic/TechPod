<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title|default('Tech Pod') }}</title>
    <link rel="stylesheet" href="/media/style/main.css">
    <link rel="icon" href="media/img/logo.svg" type="image/x-icon">
    <meta name="description" content="Tech Pod Website">
    <meta name="keywords" content="Tech Pod, Technology, Innovation">
</head>
<body class="background">
    <header>
        <div class="header">
            <div class="profile">
                <div class="profile_logo" role="button">
                    <img src="/media/img/profile_1.svg" alt="Profile Logo">
                </div>
            </div>
            <div class="search_bar">
                <input type="search" class="search_input" placeholder="Текст для поиска">
                <a class="search_btn" id="search_btn">
                    <img src="/media/img/search.svg" alt="Search Icon" class="search_icon">
                </a>
                <a class="add_card_btn" id="addCardBtn">
                    <img src="/media/img/plus.svg" alt="Add Card Icon" class="add_card_icon">
                </a>
            </div>
            <div class="logo_r">
                <a href="https://rsvpu.ru/" class="logo" id="logo" target="_blank" rel="noopener noreferrer">
                    <img src="/media/img/logo_22.svg" alt="Logo" class="logo">
                </a>
            </div>
        </div>
    </header>
    <main>
        {% block content %}{% endblock %}
    </main>

    <div class="sidebar">
        <div class="sidebar_header">
            <span>Список сотрудников</span>
            <button class="add_employee">
                <img src="/media/img/mini_plus.svg" alt="Add Employee Icon" class="add_employee_icon">
            </button>
            <button class="close_sidebar">
                <img src="/media/img/cross.svg" alt="Close Sidebar Icon" class="close_sidebar_icon">
            </button>
        </div>
        <ul class="sidebar_list">
            <!-- Список сотрудников будет загружен сюда -->
        </ul>
    </div>

    <!-- Модальное окно для добавления сотрудника -->
    <div class="modal" id="addEmployeeModal">
        <div class="modal_content">
            <span class="close_modal" id="closeAddEmployeeModal">&times;</span>
            <h3>Добавить сотрудника</h3>
            <form id="addEmployeeForm">
                <input type="text" name="first_name" placeholder="Имя" required>
                <input type="text" name="last_name" placeholder="Фамилия" required>
                <input type="email" name="email" placeholder="Email" required>
                <input type="text" name="phone" placeholder="Телефон" required>
                <input type="password" name="password" placeholder="Пароль" required>
                <button type="submit">Добавить</button>
            </form>
        </div>
    </div>

    <!-- Модальное окно для редактирования сотрудника -->
    <div class="modal" id="editEmployeeModal">
        <div class="modal_content">
            <span class="close_modal" id="closeEditEmployeeModal">&times;</span>
            <h3>Редактировать сотрудника</h3>
            <form id="editEmployeeForm">
                <input type="hidden" name="id">
                <input type="text" name="first_name" placeholder="Имя" required>
                <input type="text" name="last_name" placeholder="Фамилия" required>
                <input type="email" name="email" placeholder="Email" required>
                <input type="text" name="phone" placeholder="Телефон" required>
                <button type="submit">Сохранить изменения</button>
            </form>
        </div>
    </div>

    <script src="media/script/script.js"></script>
</body>
</html>
